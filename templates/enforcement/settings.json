{
  "permissions": {
    "ask": [
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(yarn add:*)",
      "Bash(pnpm add:*)",
      "Bash(pip install:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git filter-branch:*)",
      "Read(./.env)",
      "Edit(./.env)",
      "Write(./.env)",
      "Edit(./.github/workflows/**)",
      "Write(./.github/workflows/**)",
      "Edit(./.claude/settings.json)",
      "Write(./.claude/settings.json)",
      "Edit(./.claude/settings.local.json)",
      "Write(./.claude/settings.local.json)",
      "Edit(./powerpuff/**)",
      "Write(./powerpuff/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash powerpuff/templates/enforcement/powerpuff-guard.sh"
          }
        ]
      }
    ]
  }
}